generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Patient {
  id            String   @id @default(uuid())
  name          String
  phone         String?
  email         String?
  
  // New Personal Details
  document      String?  // CPF/RG
  birthDate     DateTime?
  gender        String?  // Masculino, Feminino, Outro
  maritalStatus String?  // Solteiro, Casado, etc.
  
  // Address Details
  address       String?
  city          String?
  state         String?
  zipCode       String?

  dentalPlan    String?  // UNIMED, OdontoPrev, etc.
  planNumber    String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  treatments        Treatment[]
  appointments  Appointment[]
  patientRecord PatientRecord?
  clinicalNotes ClinicalNote[]
  periodontalCharts PeriodontalChart[]
  attachments   Attachment[]
  transactions  Transaction[]
}

model Dentist {
  id             String   @id @default(uuid())
  name           String
  specialization String?
  color          String   @default("#4F46E5")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  appointments   Appointment[]
  scheduleBlocks ScheduleBlock[]
}

model Treatment {
  id          String   @id @default(uuid())
  name        String
  description String?
  status      String   @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  procedures Procedure[]
}

model Procedure {
  id          String   @id @default(uuid())
  name        String
  tooth       String?  // Optional tooth region (e.g., "Dente 11")
  price       Float    @default(0)
  duration    Int      @default(30) // Duration in minutes
  isCompleted Boolean  @default(false)
  
  paymentStatus String @default("PENDING") // PENDING, PAID, PARTIAL
  paidAmount    Float  @default(0)
  
  treatmentId String
  treatment   Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  appointment  Appointment?
  transactions Transaction[]
}

model Transaction {
  id          String   @id @default(uuid())
  amount      Float
  date        DateTime @default(now())
  method      String   // PIX, CARD, CASH, PLAN
  type        String   @default("INCOME") // INCOME, EXPENSE
  
  patientId   String?
  patient     Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  
  procedureId String?
  procedure   Procedure? @relation(fields: [procedureId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime @default(now())
}

model Appointment {
  id          String   @id @default(uuid())
  startTime   DateTime
  endTime     DateTime
  status      String   @default("SCHEDULED") // SCHEDULED, COMPLETED, CANCELLED
  
  whatsappSent Boolean @default(false)
  emailSent    Boolean @default(false)

  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  procedureId String?  @unique
  procedure   Procedure? @relation(fields: [procedureId], references: [id], onDelete: SetNull)
  
  dentistId   String?
  dentist     Dentist? @relation(fields: [dentistId], references: [id], onDelete: SetNull)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ScheduleBlock {
  id        String   @id @default(uuid())
  startTime DateTime
  endTime   DateTime
  reason    String?  // e.g., "Almoço", "Feriado", "Congresso"
  
  dentistId String?
  dentist   Dentist? @relation(fields: [dentistId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
}


model CatalogItem {
  id          String   @id @default(uuid())
  type        String   @default("SERVICE") // "SERVICE" or "PRODUCT"
  name        String
  description String?
  price       Float    @default(0)
  duration    Int      @default(30) // Duration in minutes, mostly for services
  color       String   @default("#3b82f6") // Hex color for the odontogram
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PatientRecord {
  id            String   @id @default(uuid())
  patientId     String   @unique
  patient       Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  medicalAlerts String?
  healthHistory String?
  allergies     String?
  medications   String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ClinicalNote {
  id          String   @id @default(uuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  date        DateTime @default(now())
  description String
  dentistName String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PeriodontalChart {
  id          String   @id @default(uuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  date        DateTime @default(now())
  data        String   // JSON string com as medições por dente
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Attachment {
  id          String   @id @default(uuid())
  patientId   String
  patient     Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  
  fileName    String
  fileType    String   // image/jpeg, image/png, application/pdf
  url         String   // Base64 ou path
  category    String?  // Radiografia, Foto, Exame, Outros
  
  createdAt   DateTime @default(now())
}
